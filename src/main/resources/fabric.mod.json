{
  "schemaVersion": 1,
  "id": "tachyon",
  "version": "${version}",
  "name": "Tachyon",
  "description": "Headless VFX rendering API for Fabric, embedding Photon and LDLib2.",
  "authors": [
    "ELB_GG"
  ],
  "contact": {
    "homepage": "https://github.com/ELBGG/Tachyon",
    "sources": "https://github.com/ELBGG/Tachyon",
    "issues": "https://github.com/ELBGG/Tachyon/issues"
  },
  "license": "LGPL-3.0-only",
  "icon": "assets/photon/textures/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "me.elb.tachyon.Tachyon"
    ],
    "client": [
      "me.elb.tachyon.client.TachyonClient"
    ]
  },
  "mixins": [
    "tachyon.mixins.json",
    "photon.mixins.json",
    "ldlib2.mixins.json"
  ],
  "accessWidener": "tachyon.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "fabric-language-kotlin": "*",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "special-model-loader": "*"
  }
}
